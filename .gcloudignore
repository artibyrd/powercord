# Inherit all standard exclusions from git
#!include:.gitignore

# EXPLICITLY INCLUDE the production secrets file so Cloud Build can execute Terraform dynamically
!.env.prod

# EXPLICITLY INCLUDE extensions installed locally so they are deployed to Cloud Build
# We use /* instead of /** to only negate the extension directories themselves,
# allowing standard .gitignore rules to still apply to their contents (like .venv)
!app/extensions/*/

# Additional Cloud Build specific ignores
.git/
.github/

