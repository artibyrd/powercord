            "column_span": 6
        },
        {
            "widget_name": "guild_admin_audit_channels_widget",
            "display_order": 5,
            "column_span": 6
        },
        {
            "widget_name": "guild_admin_audit_permissions_widget",
            "display_order": 6,
            "column_span": 12
        },
        {
            "widget_name": "guild_admin_security_overrides_widget",
