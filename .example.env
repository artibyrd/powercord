# Create a file named .env in this directory with the variables below,
# then replace the values in that file with your own.
# The .env file is used for local development ONLY.
# Actual values are stored in Google Secret Manager when deployed.
# DO NOT MODIFY THIS FILE - it is used as a manifest when fetching secrets.

# Database connection information
POSTGRES_DB=database_name_here
POSTGRES_USER=database_username_here
POSTGRES_PASSWORD=Ent3rP@$$w0rdH3r3
DB_HOST='localhost:5432'

# Discord credentials
DISCORD_TOKEN=thisiswherethediscordbottokengoes
DISCORD_CLIENT_ID=thisiswherethediscordapplicationclientidgoes
DISCORD_CLIENT_SECRET=thisiswherethediscordapplicationclientsecretgoes

# Frontend UI session key
SESSION_KEY=thisiswherethesessionkeygoes

# Endpoints to hot reload the API and bot config
API_RELOAD_URL=http://127.0.0.1:8000/reload_config # FastAPI endpoint
API_RELOAD_KEY=supersecretapireloadkey
BOT_RELOAD_URL=http://127.0.0.1:8080/reload_config # Discord webhook
BOT_RELOAD_KEY=supersecretbotreloadkey

# Base URL for OAuth redirects (must match Discord Developer Portal)
BASE_URL=http://localhost:5001

# MIDI Library Extension - Google Cloud Storage
BUCKET_URL=bgml
GCP_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/your-service-account-key.json