# Create a file named .env in this directory with the variables below,
# then replace the values in that file with your own.
# The .env file is used for local development ONLY.
# Actual values are stored in Google Secret Manager when deployed.
# DO NOT MODIFY THIS FILE - it is used as a manifest when fetching secrets.

POWERCORD_POSTGRES_DB=database_name_here
POWERCORD_POSTGRES_USER=database_username_here
POWERCORD_POSTGRES_PASSWORD=Ent3rP@$$w0rdH3r3
POWERCORD_DB_HOST='localhost:5433'

# Discord credentials
POWERCORD_DISCORD_TOKEN=thisiswherethediscordbottokengoes
POWERCORD_DISCORD_CLIENT_ID=thisiswherethediscordapplicationclientidgoes
POWERCORD_DISCORD_CLIENT_SECRET=thisiswherethediscordapplicationclientsecretgoes

# Frontend UI session key
POWERCORD_SESSION_KEY=thisiswherethesessionkeygoes

# Endpoints to hot reload the API and bot config
POWERCORD_API_RELOAD_URL=http://127.0.0.1:8000/reload_config # FastAPI endpoint
POWERCORD_API_RELOAD_KEY=supersecretapireloadkey
POWERCORD_BOT_RELOAD_URL=http://127.0.0.1:8080/reload_config # Discord webhook
POWERCORD_BOT_RELOAD_KEY=supersecretbotreloadkey

# Initial Global Admin (Auto-provisioned on startup)
POWERCORD_INITIAL_ADMIN_DISCORD_ID=your-discord-user-id

# Base URL for OAuth redirects (must match Discord Developer Portal)
POWERCORD_BASE_URL=http://localhost:5001

# Example Extension - Discord Webhook
POWERCORD_EXAMPLE_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id-here/your-webhook-token-here

# MIDI Library Extension - Google Cloud Storage
POWERCORD_BUCKET_URL=bgml
POWERCORD_GCP_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/your-service-account-key.json
